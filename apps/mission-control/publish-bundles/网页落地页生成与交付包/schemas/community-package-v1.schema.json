{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.dev/schemas/community-package-v1.json",
  "title": "OpenClaw Community Package V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packageId",
    "type",
    "name",
    "version",
    "author",
    "description",
    "capabilities",
    "dependencies",
    "compatibility",
    "permissions",
    "checksums",
    "docs",
    "assets",
    "reviewStatus",
    "visibility"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "community-package-v1"
    },
    "packageId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200
    },
    "type": {
      "type": "string",
      "enum": ["skill-pack", "sop-pack", "demo-pack", "tutorial-pack", "case-pack"]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "id": {
          "type": "string",
          "maxLength": 200
        },
        "homepage": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["official", "community", "local-export"]
        },
        "repository": {
          "type": "string",
          "maxLength": 500
        },
        "createdAt": {
          "type": "string"
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "summary": { "type": "string" },
          "entrypoint": { "type": "string" }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "kind", "required"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "kind": { "type": "string", "enum": ["skill", "foundation", "integration", "runtime", "package"] },
          "required": { "type": "boolean" },
          "installCommand": { "type": "string" },
          "installUrl": { "type": "string" },
          "bundled": { "type": "boolean" }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["openclawMinVersion", "installMode"],
      "properties": {
        "openclawMinVersion": { "type": "string" },
        "installMode": { "type": "string", "enum": ["local-console"] },
        "platforms": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "required", "reason"],
        "properties": {
          "key": {
            "type": "string",
            "enum": [
              "filesystem.read",
              "filesystem.write",
              "process.exec",
              "network.http",
              "agent.orchestration",
              "knowledge.write"
            ]
          },
          "required": { "type": "boolean" },
          "reason": { "type": "string" }
        }
      }
    },
    "checksums": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "files"],
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "sha256"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": { "type": "string" },
              "sha256": { "type": "string", "minLength": 64, "maxLength": 64 }
            }
          }
        },
        "archive": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string" },
            "sha256": { "type": "string", "minLength": 64, "maxLength": 64 }
          }
        }
      }
    },
    "docs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "path"],
        "properties": {
          "title": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind"],
        "properties": {
          "path": { "type": "string" },
          "kind": { "type": "string", "enum": ["image", "video", "document", "script", "knowledge", "archive"] },
          "label": { "type": "string" }
        }
      }
    },
    "reviewStatus": {
      "type": "string",
      "enum": ["draft", "submitted", "under_review", "changes_requested", "approved", "published", "rejected", "archived"]
    },
    "visibility": {
      "type": "string",
      "enum": ["private", "official", "community"]
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "algorithm": { "type": "string" },
        "value": { "type": "string" },
        "issuedBy": { "type": "string" }
      }
    }
  }
}
