  },
  "capabilities": [
    {
      "id": "cap.openclaw.sop.telegram-4567deb0",
      "label": "邮件每日分诊与 Telegram 推送",
      "summary": "每天自动读取一个已保存的邮箱账户档案，只抓新增/未处理邮件，产出一份分诊报告，并优先通过 OpenClaw 已连通的 WhatsApp 主通道把待你拍板的重点推送给你。",
      "entrypoint": "python3 /Users/liumobei/.openclaw/workspace/apps/mission-control/scripts/run_email_daily_triage.py --email-profile <邮箱账户档案> --notify-channel <通知通道（可选覆盖）> --mailbox-scope <邮箱范围> --time-window <时间窗口> --unread-only <是否需要只看未读> --only-unprocessed <是否需要只看未处理> --max-messages <最大邮件数> --push-mode <推送模式>"
    },
    {
      "id": "cap.openclaw.skill.assistant-orchestrator",
      "label": "assistant-orchestrator",
      "summary": "Bundled supporting capability.",
      "entrypoint": ""
