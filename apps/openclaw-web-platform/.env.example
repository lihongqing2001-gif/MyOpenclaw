# Optional SMTP email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional package source directory for official packages
OPENCLAW_OFFICIAL_PACKAGE_DIR=
