PORT=3400
NODE_ENV=development
OPENCLAW_WEB_DATA_DIR=./data
OPENCLAW_WEB_SESSION_SECRET=change-me
OPENCLAW_WEB_DOWNLOAD_SECRET=change-me-too
OPENCLAW_WEB_BASE_URL=http://127.0.0.1:3400
GITHUB_CLIENT_ID=
