{
  "name": "solo-core-hub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "NODE_ENV=production node dist-server/server.js",
    "start:tsx": "NODE_ENV=production tsx server.ts",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node20 --format=esm --packages=external --outfile=dist-server/server.js",
    "build": "npm run build:client && npm run build:server",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.client.json",
    "bootstrap-admin": "tsx scripts/bootstrap_admin.ts",
    "publish-package": "tsx scripts/publish_package.ts",
    "migrate:file-store": "tsx scripts/migrate_file_store_to_postgres.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@aws-sdk/s3-request-presigner": "^3.1015.0",
    "@types/pg": "^8.20.0",
    "adm-zip": "^0.5.16",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^1.0.1",
    "motion": "^12.38.0",
    "multer": "^2.0.2",
    "nodemailer": "^6.10.1",
    "otplib": "^12.0.1",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/adm-zip": "^0.5.8",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.27.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vite": "^8.0.2"
  }
}
