PORT=3400
NODE_ENV=production
OPENCLAW_WEB_DATA_DIR=/var/lib/openclaw-web-platform/data
OPENCLAW_WEB_SESSION_SECRET=replace-with-long-random-secret
OPENCLAW_WEB_DOWNLOAD_SECRET=replace-with-long-random-secret
OPENCLAW_WEB_BASE_URL=https://your-domain.example
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me
GITHUB_CALLBACK_URL=https://app.your-domain.example/auth/github/callback
GITHUB_RELEASE_REPO=owner/repo
GITHUB_TOKEN=replace-me
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=replace-me
SMTP_FROM=OpenClaw <mailer@example.com>
OPENCLAW_OFFICIAL_PACKAGE_DIR=/var/lib/openclaw-web-platform/official-packages
