PORT=3400
NODE_ENV=production
OPENCLAW_WEB_DATA_DIR=/var/lib/openclaw-web-platform/data
DATABASE_URL=postgresql://openclaw_web:replace-me@127.0.0.1:5432/openclaw_web
OPENCLAW_WEB_POSTGRES_TABLE=openclaw_state
OPENCLAW_WEB_SESSION_SECRET=replace-with-long-random-secret
OPENCLAW_WEB_DOWNLOAD_SECRET=replace-with-long-random-secret
OPENCLAW_WEB_BASE_URL=https://your-domain.example
OPENCLAW_FORGE_CONSOLE_RELEASES_DIR=/var/lib/openclaw-web-platform/forge-console/releases
SOLOCORE_CLOUD_CONSOLE_URL=http://127.0.0.1:3000
SOLOCORE_CLOUD_CONSOLE_PUBLIC_URL=https://console.your-domain.example
SOLOCORE_CONSOLE_ACCESS_SECRET=replace-with-shared-console-access-secret
SOLOCORE_CLOUD_CONSOLE_INTERNAL_TOKEN=replace-with-internal-console-admin-token
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me
GITHUB_CALLBACK_URL=https://app.your-domain.example/auth/github/callback
GITHUB_RELEASE_REPO=owner/repo
GITHUB_TOKEN=replace-me
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-qq-mail@qq.com
SMTP_PASS=replace-with-qq-mail-authorize-code
SMTP_FROM=SoloCore Hub <your-qq-mail@qq.com>
OPENCLAW_OFFICIAL_PACKAGE_DIR=/var/lib/openclaw-web-platform/official-packages
